# Free RAG Chatbot - No paid API keys needed!
# Copy to .env and adjust if needed

# Database (used by backend)
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@db:5432/ragdb
DATABASE_SYNC_URL=postgresql://raguser:ragpass@db:5432/ragdb

# Ollama settings (free local LLM)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2          # Change to: mistral, llama3.1, phi3, etc.
OLLAMA_EMBED_MODEL=nomic-embed-text

# Embedding backend: "ollama" (recommended) or "sentence_transformers"
EMBEDDING_BACKEND=ollama

# App
DEBUG=false
